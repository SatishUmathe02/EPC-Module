<script type="text/javascript">

    function SubmitBtnAction()
    {
        var Meg = "This action will increment the serial number in the EPC module permanently and cannot be reversed. Are you sure you want to proceed?";

        var g = confirm(Meg);

        if (g == true)
        {
            return true
        }else
        {
            return false
        }
        
    }

    function JsonChange() {


        var CustomerID = $("#EPCRequest_CustomerID").val();
        var GTIN = $("#EPCRequest_GTIN").val();
        var Quantity = $("#EPCRequest_Quantity").val();
        var RPO = $("#EPCRequest_RPO").val();
        var DetailLineID = $("#EPCRequest_DetailLineID").val();


        $.get("r-tracEPC/EPCModule/GetJSON", { CustomerID: CustomerID, GTIN: GTIN, Quantity: Quantity, RPO: RPO, DetailLineID: DetailLineID }, function (data) {
            $("#Request_New").val() = data

            $("#btn_Response_Cont").click();
        });


        return false;
    }

