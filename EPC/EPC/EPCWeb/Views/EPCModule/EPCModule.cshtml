@model EPCWeb.Models.EPCModel
@{
    ViewBag.Title = "EPCModule";
}

<style>
    table#t01 {
        width: 100%;
        background-color: #f1f1c1;
    }

        table#t01 tr:nth-child(even) {
            background-color: #eee;
        }

        table#t01 tr:nth-child(odd) {
            background-color: #fff;
        }

        table#t01 th {
            color: white;
            background-color: #428bca;
        }
</style>



<div class="panel panel-primary" id="content">

    <div class="panel-heading"> EPC Module Dashbord</div>

    <div class="row" style="margin:10px;">
        <div class="col-md-12 subTab">
            <div id="myTabContent" class="tab-content">
                <br />

                @using (Html.BeginForm("GetResponse", "EPCModule", FormMethod.Post, new { @class = "form -horizontal", @id = "contactForm" }))
                {

                    <div class="row form-group" style="margin:10px; display:none">

                        <div class="col-md-5">
                            <table>
                                <tr><td><label>Schema:</label></td><td></td><td>@Model.EPCRequest.Schema</td></tr>
                                <tr><td><label>CustomerName:</label></td><td></td><td>@Html.DropDownListFor(Model => Model.EPCRequest.CustomerID, Model.CustomerList, new { @class = "form-control" })</td></tr>
                                <tr><td><label>GTIN:</label></td><td></td><td>@Html.TextBoxFor(Model => Model.EPCRequest.GTIN, new { @class = "form-control" })</td></tr>
                                <tr><td><label>Quantity:</label></td><td></td><td>@Html.TextBoxFor(Model => Model.EPCRequest.Quantity, new { @class = "form-control" })</td></tr>
                                <tr><td><label>RPO:</label></td><td></td><td>@Html.TextBoxFor(Model => Model.EPCRequest.RPO, new { @class = "form-control" })</td></tr>
                                <tr><td><label>DetailLineID:</label></td><td></td><td>@Html.TextBoxFor(Model => Model.EPCRequest.DetailLineID, new { @class = "form-control", @onchange = "JsonChange();" })</td></tr>
                            </table>
                        </div>
                        <div class="col-md-2">


                            <br /><br /><br /><br /><br /><br /><br /><br /><br />
                            
                            <input type="submit" class="btn btn-primary red" id="btnSearch" onclick="return SubmitBtnAction();"  value="Submit">


                        </div>
                        <div class="col-md-5">
                            <table>
                                <tr><td><label>EPCStart:</label></td><td></td><td>@Model.EPCResponse.EPCStart</td></tr>
                                <tr><td><label>EPCEnd:</label></td><td></td><td>@Model.EPCResponse.EPCEnd</td></tr>
                                <tr><td><label>SerialStart:</label></td><td></td><td>@Model.EPCResponse.SerialStart</td></tr>
                                <tr><td><label>SerialEnd:</label></td><td></td><td>@Model.EPCResponse.SerialEnd</td></tr>
                                <tr><td><label>CustomerID:</label></td><td></td><td>@Model.EPCResponse.CustomerID</td></tr>
                                <tr><td><label>GTIN:</label></td><td></td><td>@Model.EPCResponse.GTIN</td></tr>
                                <tr><td><label>Quantity:</label></td><td></td><td>@Model.EPCResponse.Quantity</td></tr>
                                <tr><td style="vertical-align:top"><label>Remark:</label></td><td></td><td>@Model.EPCResponse.Remark</td></tr>
                            </table>
                        </div>
                    </div>

                    @*if (Model.EPCCounterList.Count > 0)
                    {
                        <hr style="margin-top: 5px !important ;margin-bottom: 5px !important;">
                        <div class="row form-group" style="margin:10px;">
                            <div class="col-md-12">
                                <h3>EPC Counter Data</h3>
                                <div>
                                    <table id="t01">
                                        <thead>
                                        <th>Line No</th>
                                        <th>GTIN</th>
                                        <th>EPC</th>
                                        <th>SerialNo</th>
                                        <th>Access PWD</th>
                                        <th>Kill PWD</th>
                                        </thead>
                                        @foreach (var item in Model.EPCCounterList)
                                    {

                                        <tr>
                                            <td>
                                                @item.LineNo
                                            </td>
                                            <td>
                                                @item.GTIN
                                            </td>
                                            <td>
                                                @item.EPC
                                            </td>
                                            <td>
                                                @item.SerialNo
                                            </td>
                                            <td>
                                                @item.Password
                                            </td>
                                            <td>
                                                @item.KillPassword
                                            </td>
                                        </tr>

                                    }

                                    </table>
                                </div>

                            </div>
                        </div>
                    }

                    if (Model.GS1_Info.Count > 0)
                    {
                        <hr style="margin-top: 5px !important ;margin-bottom: 5px !important;">
                        <div class="row form-group" style="margin:10px;">
                            <div class="col-md-12">
                                <h3>GS1 Data</h3>

                                <div class="col-md-5">
                                    <table>
                                        <tr><td><label>Source:</label></td><td></td><td>@Model.GS1_Info[0].Source</td></tr>
                                        <tr><td><label>EntityGLN:</label></td><td></td><td>@Model.GS1_Info[0].EntityGLN</td></tr>
                                        <tr><td><label>CompanyName:</label></td><td></td><td>@Model.GS1_Info[0].CompanyName</td></tr>
                                        <tr><td><label>StreetAddress1:</label></td><td></td><td>@Model.GS1_Info[0].StreetAddress1</td></tr>
                                        <tr><td><label>StreetAddress2:</label></td><td></td><td>@Model.GS1_Info[0].StreetAddress2</td></tr>
                                        <tr><td><label>StreetAddress3:</label></td><td></td><td>@Model.GS1_Info[0].StreetAddress3</td></tr>
                                        <tr><td><label>City:</label></td><td></td><td>@Model.GS1_Info[0].City</td></tr>
                                        <tr><td><label>StateProvince:</label></td><td></td><td>@Model.GS1_Info[0].StateProvince</td></tr>
                                        <tr><td><label>ZipCode:</label></td><td></td><td>@Model.GS1_Info[0].ZipCode</td></tr>
                                        <tr><td><label>Country:</label></td><td></td><td>@Model.GS1_Info[0].Country</td></tr>
                                    </table>
                                </div>
                                <div class="col-md-2"></div>
                                    <div class="col-md-5">
                                        <table>
                                            <tr><td><label>GSRN:</label></td><td></td><td>@Model.GS1_Info[0].GSRN</td></tr>
                                            <tr><td><label>ModifiedDate:</label></td><td></td><td>@Model.GS1_Info[0].ModifiedDate</td></tr>
                                            <tr><td><label>UPCPrefix:</label></td><td></td><td>@Model.GS1_Info[0].Prefixes.UPCPrefix</td></tr>
                                            <tr><td><label>GS1Prefix:</label></td><td></td><td>@Model.GS1_Info[0].Prefixes.GS1Prefix</td></tr>
                                            <tr><td><label>PrefixStatus:</label></td><td></td><td>@Model.GS1_Info[0].Prefixes.PrefixStatus</td></tr>
                                            <tr><td><label>Prefixes ModifiedDate:</label></td><td></td><td>@Model.GS1_Info[0].Prefixes.ModifiedDate</td></tr>

                                        </table>
                                    </div>
                                    <div>
                                       
                                    </div>



                                </div>
                        </div>
                    }
                    else
                    {
                        <label>@Model.GS1_Error</label>
                    }*@
                }

                @using (Html.BeginForm("GetJSONResponse", "EPCModule", FormMethod.Post, new { @class = "form -horizontal", @id = "contactForm" }))
                {
                    <div class="active" id="costHead">
                        <br />

                        <div class="row form-group" style="margin:10px; display:block">


                            <div class="col-md-5">
                                <label>JSON Request</label>
                                @Html.TextAreaFor(Model => Model.Request, new { @class = "form-control", @style = "margin: 0px 27.25px 0px 0px; height: 334px; width: 530px; max-width:100% !important" })
                            </div>

                            <div class="col-md-2">

                                <br /><br /><br /><br /><br /><br /><br /><br /><br />
                                <input type="submit" class="btn btn-primary red" id="btnSearch" value="Submit">


                            </div>
                            <div class="col-md-5">
                                <label>JSON Response</label>


                                @Html.TextArea("name", (string)ViewBag.Response, new { @class = "form-control", @style = "margin: 0px 27.25px 0px 0px; height: 331px; width: 540px; max-width:100% !important", })
                            </div>
                        </div>

                        <div class="row" id="tbldata2">
                            <div class="col-md-12">

                            </div>
                        </div>


                    </div>
                }


            </div>
        </div>
    </div>
